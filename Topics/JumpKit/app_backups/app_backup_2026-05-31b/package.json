{
  "name": "jumpkit",
  "version": "1.0.0",
  "description": "JumpKit — Your instant jump launcher",
  "main": "main.js",
  "author": "Jeff",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.jumpkit.app",
    "productName": "JumpKit",
    "copyright": "Copyright © 2026 Jeff",
    "afterPack": "./fuse.js",
    "files": [
      "**/*",
      "!node_modules/.bin",
      "!**/*.map",
      "!server.js",
      "!data/db.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "darkModeSupport": true,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "dmg": {
      "title": "JumpKit",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "assets/icon_gradient_512.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "jrod4404",
      "repo": "JumpKit"
    }
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3",
    "express": "^4.22.1"
  }
}
