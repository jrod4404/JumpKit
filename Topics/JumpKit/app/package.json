{
  "name": "jumpkit",
  "version": "1.0.0",
  "description": "JumpKit — Your instant jump launcher",
  "main": "main.js",
  "author": "Jeff",
  "scripts": {
    "test": "node --test test/**/*.mjs",
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "build:test": "electron-builder --mac --config electron-builder.test.json",
    "build:test:win": "electron-builder --win --config electron-builder.test.json",
    "build:test:all": "electron-builder --mac --win --config electron-builder.test.json"
  },
  "build": {
    "appId": "com.jumpkit.app",
    "productName": "JumpKit",
    "copyright": "Copyright © 2026 Jeff",
    "afterPack": "./fuse.js",
    "files": [
      "**/*",
      "!node_modules/.bin",
      "!**/*.map",
      "!server.js",
      "!data/db.json",
      "!js/tests.js",
      "!js/tests.js.bak",
      "!js/deployment.js",
      "!js/admin.js"
    ],
    "afterSign": "./notarize.js",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "identity": "Jeff Roder (ZDJSH728ND)",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "darkModeSupport": true,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "dmg": {
      "title": "JumpKit",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "assets/icon_gradient_512.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "jrod4404",
      "repo": "JumpKit"
    }
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "dotenv": "^17.4.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3",
    "express": "^4.22.1"
  }
}
